# Supabase
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_CACHE_TTL_MS=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# Twilio — REQUIRED for OTP delivery
TWILIO_ACCOUNT_SID=your-twilio-account-sid
# Option 1: API Keys (recommended — more secure)
TWILIO_API_KEY_SID=your-twilio-api-key-sid
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret
# Option 2: Auth Token (legacy — less secure)
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# CRITICAL — Verify Service SID (Twilio Console → Verify → Services)
# OTPs will not be sent without this variable
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# Server
PORT=3001
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:8081
ADMIN_FRONTEND_URL=http://localhost:3000
POS_FRONTEND_URL=http://localhost:3000

# Expo (push notifications)
EXPO_PROJECT_ID=your-eas-project-id
EXPO_LEGACY_EXPERIENCE_KEY=@your-expo-username/demo-finance-app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# MT Center API (international top-ups / bill pay)
# Testing environment: https://mtcdes.com.mx/clientes/api/
# Production: provided by MT Center after certification
MT_CENTER_API_URL=https://your-mt-center-api.example.com
MT_CENTER_CADENA=your-cadena-id
MT_CENTER_ESTABLECIMIENTO=your-establecimiento-id
MT_CENTER_TERMINAL=your-terminal-id
MT_CENTER_CAJERO=your-cajero-id
MT_CENTER_CLAVE=your-mt-center-password

# OpenPay (card deposits)
# Sandbox: https://sandbox-api.openpay.mx/v1
# Production: https://api.openpay.mx/v1
OPENPAY_API_URL=https://sandbox-api.openpay.mx/v1
OPENPAY_MERCHANT_ID=your-openpay-merchant-id
OPENPAY_PRIVATE_KEY=your-openpay-private-key
OPENPAY_POS_API_KEY=your-openpay-pos-api-key
